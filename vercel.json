{
  "rewrites": [{ "source": "/((?!api/).*)", "destination": "/" }],
  "functions": {
    "api/chat.js": { "maxDuration": 60 }
  },
  "crons": [
    {
      "path": "/api/notify-slack",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/weekly-summary",
      "schedule": "30 23 * * 0"
    }
  ]
}
